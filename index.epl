<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<link href="bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
	<title>Drag & Drop Upload movie file to LED controller</title>
	<style>
		.card { border: 1px solid rgba(0,0,0,0); border-radius: .25rem; background-color: #fff; }
		#drag_drop {
			background-color: #f9f9f9;
			border: #ccc 4px dashed;
			padding: 20px;
			text-align: center;
			cursor: pointer;
		}
		.slitscan { max-width: 100%; height: auto; }
	</style>
</head>
<body>

<div class="container mt-5">
	<div class="card">
		<div class="card-body">
			<div class="row">
				<div class="col-md-3">&nbsp;</div>
				<div class="col-md-6">
					<h4 class="mb-3 text-center">Drag & drop movie file or click image to upload</h4>
					
					<div id="drag_drop">
						<!-- Progress bar moved to the top -->
						<div class="progress mb-3" id="progress_bar" style="display:none; height:50px;">
							<div class="progress-bar bg-success" id="progress_bar_process" role="progressbar" style="width:0%; height:50px;">0%</div>
						</div>

						<!-- Image link below the progress bar -->
						<a id="upload_link" style="cursor: pointer;">
							<img class="slitscan" id="slitscan" src="images/slitscan.png" alt="Upload">
						</a>
						<input type="file" id="file_input" style="display: none;" accept="video/*">
					</div>
					
					<div id="uploaded_image" class="row mt-2"></div>
				</div>
				<div class="col-md-3">&nbsp;</div>
			</div>
		</div>
	</div>
</div>

<script src="upload.js"></script>
</body>
</html>
